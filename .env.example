# Mining Intellect Backend v2 — Environment Variables
# Copy this file to .env and fill in the values

# ── LLM ──────────────────────────────────────────────────────────────────────
GROK_API_KEY=xai-...               # xAI Grok (primary LLM)
ANTHROPIC_API_KEY=sk-ant-...       # Claude (fallback, optional)

# ── Exa ──────────────────────────────────────────────────────────────────────
EXA_API_KEY=...                    # Exa deep-search API key

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Service role key (bypasses RLS)

# ── LangSmith (tracing) ───────────────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=mining-intellect-v2
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── LangGraph Cloud (used by pipeline_orchestrator to start child graphs) ──────
LANGGRAPH_API_KEY=lsv2__...        # LangGraph Cloud API key
LANGGRAPH_BASE_URL=https://vishesh-mi-backend-960260026e5555ce9409bc144c51efc8.us.langgraph.app

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
